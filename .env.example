# FinViz Elite API key (used by post_scans_elite.py and bot slash commands)
FINVIZ_API_KEY=your_finviz_elite_api_key_here

# Discord bot token (required for bot.py)
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Optional: test / dev Discord server ID(s) — instant slash command sync there first.
# Default when GUILD_ID is set: ALSO sync globally so every other server gets commands (up to ~1 hour).
# Use one ID or comma-separated: 111...,222...
# Leave GUILD_ID unset to register commands globally only.
# GUILD_ID=123456789012345678

# Set to 1 to disable global sync and only register slash commands on the guild(s) in GUILD_ID (old behavior).
# SLASH_GUILD_ONLY=1

# Guild-only mode only: set to 1 to clear global slash commands and avoid duplicate / lines in the picker.
# Ignored when global sync is enabled (dual sync). Do not use if you need commands on servers not in GUILD_ID.
# SLASH_CLEAR_GLOBAL_FOR_DEDUPE=1

# Optional: delay between FinViz requests (seconds)
# FINVIZ_ELITE_DELAY_SEC=1.5
# FINVIZ_FREE_DELAY_SEC=4

# Top gainers/losers: FinViz CSV volume is usually in thousands; min_volume on /top_* is in shares.
# Set to "shares" if your export already lists full share counts.
# FINVIZ_MOVERS_VOLUME_CSV_UNIT=thousands

# Optional: post_heatmaps_elite.py — incoming webhook URL (overrides webhooks.json "heatmaps" key)
# HEATMAP_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Optional: v=152 full export HTTP read timeout in seconds (large CSV)
# FINVIZ_V152_EXPORT_TIMEOUT_SEC=180
