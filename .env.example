# FinViz Elite API key (used by post_scans_elite.py and bot slash commands)
FINVIZ_API_KEY=your_finviz_elite_api_key_here

# Discord bot token (required for bot.py)
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Optional: test / dev Discord server ID(s) — instant slash command sync there first.
# Default when GUILD_ID is set: guild-only (no global) so duplicate /commands do not appear in the picker.
# Use one ID or comma-separated: 111...,222...
# Leave GUILD_ID unset to register commands globally only (~1 hour propagation).
# GUILD_ID=123456789012345678

# Also register slash commands globally when GUILD_ID is set (dual sync). Other servers get commands
# within ~1 hour; your test guild may show duplicate slash entries until Discord dedupes.
# SLASH_SYNC_GLOBAL_ALSO=1

# Set to 1 to force guild-only registration even if SLASH_SYNC_GLOBAL_ALSO=1 (only listed guilds).
# SLASH_GUILD_ONLY=1

# When not using global sync: run once with this to clear stale global registrations (fixes duplicate
# /commands after switching from dual sync to guild-only). Do not use while SLASH_SYNC_GLOBAL_ALSO=1.
# SLASH_CLEAR_GLOBAL_FOR_DEDUPE=1

# Optional: delay between FinViz requests (seconds)
# FINVIZ_ELITE_DELAY_SEC=1.5
# FINVIZ_FREE_DELAY_SEC=4

# Top gainers/losers: FinViz CSV volume is usually in thousands; min_volume on /top_* is in shares.
# Set to "shares" if your export already lists full share counts.
# FINVIZ_MOVERS_VOLUME_CSV_UNIT=thousands

# Optional: v=152 full export HTTP read timeout in seconds (/heatmap, large CSV)
# FINVIZ_V152_EXPORT_TIMEOUT_SEC=180

# Railway (optional): set in service Variables so Python logs stream without buffering
# PYTHONUNBUFFERED=1
