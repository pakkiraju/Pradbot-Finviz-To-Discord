# FinViz Elite API key (used by post_scans_elite.py and the bot's !chart command)
FINVIZ_API_KEY=your_finviz_elite_api_key_here

# Discord bot token (required for bot.py)
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Optional: delay between FinViz requests (seconds)
# FINVIZ_ELITE_DELAY_SEC=1.5
# FINVIZ_FREE_DELAY_SEC=4
