# Railway branch: add these in Railway → your Worker service → Variables (do not commit secrets).
# Required:
DISCORD_BOT_TOKEN=
FINVIZ_API_KEY=

# Required for /inplay scanner:Earnings only (Massive.com REST; Polygon keys work too):
# MASSIVE_API_KEY=
# POLYGON_API_KEY=

# Optional:
# GUILD_ID=
# SLASH_SYNC_GLOBAL_ALSO=1
# SLASH_GUILD_ONLY=1
# SLASH_CLEAR_GLOBAL_FOR_DEDUPE=1
# FINVIZ_ELITE_DELAY_SEC=1.5
# FINVIZ_V152_EXPORT_TIMEOUT_SEC=180
# FINVIZ_MOVERS_VOLUME_CSV_UNIT=thousands
# PYTHONUNBUFFERED=1
