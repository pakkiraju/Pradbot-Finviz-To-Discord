# Railway branch: add these in Railway → your Worker service → Variables (do not commit secrets).
# Required:
DISCORD_BOT_TOKEN=
FINVIZ_API_KEY=

# Required for /inplay scanner:Earnings and /top_opps execution study (Massive.com REST; Polygon keys work too):
# MASSIVE_API_KEY=
# POLYGON_API_KEY=

# Optional:
# README for /help — GitHub anchor URLs need #. In a local .env file use quotes (dotenv treats # as comment).
# In Railway Variables, enter the URL without quotes; the bot strips accidental surrounding quotes.
# README_URL="https://github.com/YOUR_ORG/YOUR_REPO#readme"
# GUILD_ID=
# SLASH_SYNC_GLOBAL_ALSO=1
# SLASH_GUILD_ONLY=1
# SLASH_CLEAR_GLOBAL_FOR_DEDUPE=1
# FINVIZ_ELITE_DELAY_SEC=1.5
# FINVIZ_V152_EXPORT_TIMEOUT_SEC=180
# FINVIZ_MOVERS_VOLUME_CSV_UNIT=thousands
# PYTHONUNBUFFERED=1

# /top_opps → Notion (optional): after charts + snapshot, user TOP_OPPS_NOTION_USERNAME (default traderprad) gets an ephemeral "Save to Notion" button.
# Create a Notion integration and connect it to your workspace. First save auto-adds missing columns (default ON).
# NOTION_API_KEY=secret_...
# NOTION_TOP_OPPS_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Use the **database** id (full-page database URL). If you paste a **page** id, the bot will try to find an embedded database on that page.
# Inline / 2025+ databases: schema lives on a **data source** — the bot loads that automatically (requires NOTION_API_VERSION 2025-09-03 or newer, default 2026-03-11).
# TOP_OPPS_NOTION_USERNAME=traderprad
# NOTION_TOP_OPPS_AUTO_SCHEMA=1
# NOTION_API_VERSION=2026-03-11
# New database with full schema (optional): set NOTION_TOP_OPPS_PARENT_PAGE_ID to a page ID, then:
#   python notion_top_opps.py --create-db
# NOTION_TOP_OPPS_PARENT_PAGE_ID=
